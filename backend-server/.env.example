# Required / 必填: Prisma SQLite connection string
DATABASE_URL="file:./dev.db"

# Optional, has default / 可选，有默认值: Service port
PORT=3001

# Optional, has default / 可选，有默认值: AI service base URL
AI_SERVICE_BASE_URL=http://127.0.0.1:8000

# Optional, but must match AI-server if enabled / 可选，若启用需与 AI-server 保持一致
AI_SERVICE_SHARED_SECRET=

# Optional, has default / 可选，有默认值: Single file upload size limit in MB
UPLOAD_MAX_FILE_SIZE_MB=20

# Optional, has default / 可选，有默认值: Upstream AI service timeout in milliseconds
AI_SERVICE_TIMEOUT_MS=12000

# Optional override / 可选覆盖: Full ingestion endpoint URL
AI_INGESTION_ENDPOINT=

# Optional override / 可选覆盖: Full vector delete endpoint prefix URL
AI_VECTOR_DELETE_ENDPOINT=

# Optional mock timing config / 可选 mock 入库延迟配置
MOCK_INGEST_RUNNING_DELAY_MS=800
MOCK_INGEST_DONE_DELAY_MS=2200

# Optional mock failure flag / 可选 mock 失败开关, 1 means fail / 1 表示模拟失败
MOCK_INGEST_FAIL=0
