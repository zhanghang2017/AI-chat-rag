# Required for ingestion / 入库必填: Zhipu embedding key used for knowledge ingestion
ZHIPUAI_API_KEY=

# Optional, has default / 可选，默认 http://127.0.0.1:3001/v1: Node backend callback base url
NODE_BASE_URL=http://127.0.0.1:3001/v1

# Optional, but must match backend if enabled / 可选，若启用需与 backend 保持一致
AI_SERVICE_SHARED_SECRET=

# Optional, has default / 可选，有默认值: Chroma settings
CHROMA_PERSIST_DIRECTORY=
CHROMA_COLLECTION_NAME=knowledge_chunks

# Optional, has defaults / 可选，有默认值: Ingestion settings
INGEST_CHUNK_SIZE=800
INGEST_CHUNK_OVERLAP=120
EMBEDDING_BATCH_SIZE=64
NODE_CALLBACK_TIMEOUT_SECONDS=10

# Required for chat / 聊天必填: Chat model settings
OPENAI_API_KEY=
# Recommended to fill explicitly / 建议显式填写，避免依赖服务端默认模型
OPENAI_CHAT_MODEL=
# Optional if provider SDK already has a default base URL / 若服务商 SDK 自带默认地址，可留空
OPENAI_BASE_URL=

# Optional, has defaults / 可选，有默认值: Retrieval settings
CHAT_RETRIEVAL_TOP_K=5
CHAT_CONTEXT_MESSAGE_LIMIT=12

# Optional app config / 可选服务配置
HOST=127.0.0.1
PORT=8000